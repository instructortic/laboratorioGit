Algoritmo Ingreso_Nombre
	Definir nombre Como Caracter;
	Definir edad Como entero;
	Definir apellido Como Caracter
	Escribir "Ingrese el nombre de la persona";
	Leer nombre; 
	Escribir " Ingrese apellido porfavor"
	Leer apellido;
	Escribir "ingrese edad";
	Leer edad;
	
	Imprimir "Tu nombre es: ", nombre," ",apellido," ",edad;
	
	
FinAlgoritmo
